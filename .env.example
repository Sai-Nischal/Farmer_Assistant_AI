# Rythu Mitra AI Environment Configuration

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=dev_secret_key_change_in_production

# Gemini API Key (Required for Diagnosis and Advisory agents)
GEMINI_API_KEY=your_gemini_api_key_here

# Weather API Configuration (Optional: Open-Meteo is free and doesn't require a key)
# If using OpenWeatherMap as a fallback, specify key below
OPENWEATHERMAP_API_KEY=
